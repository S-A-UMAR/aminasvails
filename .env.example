# Amina's Vails - Environment Variables Example
# Copy this file to .env and fill in the actual values for local/production use

# Django Secret Key (generate a new one for production)
SECRET_KEY=your-secret-key-here

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated, e.g. yourdomain.com,www.yourdomain.com,.vercel.app)
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Database Connection (TiDB Cloud MySQL format)
# Format: mysql://<username>:<password>@<host>:4000/<database>
# Leave commented out to use local SQLite in development
# DATABASE_URL=mysql://xxxxxx.root:password@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/aminasvails

# Cloudinary Media Storage Credentials
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# WhatsApp Business phone number (with country code, no + sign)
# Example: +234 080 000 0000 → 2348000000000
WHATSAPP_BUSINESS_NUMBER=2348000000000

# Security Settings for Production only (leave commented for development)
# SECURE_SSL_REDIRECT=True
